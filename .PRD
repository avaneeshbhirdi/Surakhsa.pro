## 14. Data Models

### events

```sql
events (
  id            UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  admin_id      UUID REFERENCES users(id),
  name          TEXT NOT NULL,
  venue_name    TEXT,
  event_date    TIMESTAMPTZ,
  status        TEXT DEFAULT 'DRAFT',  -- DRAFT|ACTIVE|PAUSED|ENDED
  pin           TEXT NOT NULL UNIQUE,
  total_capacity INT,
  created_at    TIMESTAMPTZ DEFAULT NOW()
)
```

### zones

```sql
zones (
  id            UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  event_id      UUID REFERENCES events(id) ON DELETE CASCADE,
  label         TEXT NOT NULL,   -- "A", "B", "C"
  name          TEXT,            -- "North Gate", "Main Stage"
  capacity      INT NOT NULL,
  created_at    TIMESTAMPTZ DEFAULT NOW()
)
```

### zone_readings

```sql
zone_readings (
  id            UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  zone_id       UUID REFERENCES zones(id),
  event_id      UUID REFERENCES events(id),
  density       FLOAT,
  flow_rate     FLOAT,
  risk_score    INT,
  risk_type     TEXT,  -- SURGE|BOTTLENECK|STAMPEDE_RISK|NORMAL
  confidence    TEXT,  -- LOW|MEDIUM|HIGH
  color_state   TEXT,  -- GREEN|YELLOW|RED
  recorded_at   TIMESTAMPTZ DEFAULT NOW()
)
```

### alerts

```sql
alerts (
  id              UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  event_id        UUID REFERENCES events(id),
  zone_id         UUID REFERENCES zones(id),
  risk_type       TEXT NOT NULL,
  risk_score      INT,
  priority        TEXT NOT NULL,  -- LOW|MEDIUM|HIGH|CRITICAL
  message         TEXT NOT NULL,
  action          TEXT,
  status          TEXT DEFAULT 'TRIGGERED',  -- TRIGGERED|ACKNOWLEDGED|RESOLVED
  acknowledged_by UUID REFERENCES users(id),
  triggered_at    TIMESTAMPTZ DEFAULT NOW(),
  resolved_at     TIMESTAMPTZ
)
```

### event_staff

```sql
event_staff (
  id            UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  event_id      UUID REFERENCES events(id),
  user_id       UUID REFERENCES users(id) NULLABLE,  -- NULL for PIN-only stewards
  display_name  TEXT NOT NULL,
  role          TEXT NOT NULL,  -- ADMIN|COORDINATOR|STEWARD
  zone_id       UUID REFERENCES zones(id) NULLABLE,
  session_token TEXT,
  joined_at     TIMESTAMPTZ DEFAULT NOW(),
  left_at       TIMESTAMPTZ
)
```

### steward_updates

```sql
steward_updates (
  id         UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  event_id   UUID REFERENCES events(id),
  zone_id    UUID REFERENCES zones(id),
  staff_id   UUID REFERENCES event_staff(id),
  status     TEXT NOT NULL,  -- ALL_CLEAR|CROWD_BUILDING|EMERGENCY
  created_at TIMESTAMPTZ DEFAULT NOW()
)
```

